{
  "name": "robtic-system",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "bun --preload ./libs/shared/src/preload.ts --watch apps/bot/src/index.ts",
    "dev:activity": "cd apps/activity && bun run dev",
    "dev:api": "bun --preload ./libs/shared/src/preload.ts --watch apps/api/src/index.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:5173",
    "build": "bun build ./apps/bot/src/index.ts --outfile ./dist/index.js --target bun",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production bun dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "groq-sdk": "^0.37.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "discord.js": "^14.26.4",
    "dotenv": "latest",
    "mongoose": "^9.7.2",
    "node-cron": "^4.5.0"
  }
}
