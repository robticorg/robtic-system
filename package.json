    "@types/passport-discord": "^0.1.15",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "groq-sdk": "^0.37.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "connect-mongo": "^6.0.0",
