TestBot=
MainBotToken=
CommunityBotToken=
ModerationBotToken=
ModeMailBotToken=
HRBotToken=
DevBotToken=

STATUS_WEBHOOK=
MONGODB_URI=mongodb://localhost:27017/robtic

TestGuild=
MainGuild=

NODE_ENV=development

# =============================
# GROQ AI CONFIG
# =============================

GROQ_API_KEY=

AI_MODEL=

AI_TIMEOUT_MS=

AI_ENABLED=


# =============================
# OPTIONAL FALLBACK SETTINGS
# =============================

AI_MIN_MESSAGE_LENGTH=
AI_SUPPORT_CHANNEL_ONLY=


# =============================
# DISCORD ACTIVITY / EMBEDDED APP SDK
# =============================

# From the Discord Developer Portal -> your application -> OAuth2.
# VITE_DISCORD_CLIENT_ID is exposed to the browser (public); it is the same
# application id as DISCORD_CLIENT_ID, duplicated because only VITE_-prefixed
# vars reach the Vite client.
VITE_DISCORD_CLIENT_ID=

# Used by apps/api for the OAuth2 code -> access token exchange.
DISCORD_CLIENT_ID=
# NEVER expose this to the client. Portal -> OAuth2 -> Client Secret.
DISCORD_CLIENT_SECRET=

# Port for apps/api (token exchange + future REST/WS). The activity dev server
# proxies /.proxy/* to this port locally.
API_PORT=3001